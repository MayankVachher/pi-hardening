# =============================================================================
# AI Sandbox Caddyfile — owned by the AI user, fully under AI's control
# Location: /srv/<ai-user>/Caddyfile
#
# How this works:
#   The main Caddy (root-owned, on :443) forwards all traffic for
#   ai.yourdomain.com to port 4000. THIS Caddy instance listens on :4000
#   and routes requests to whatever the AI is running on higher ports.
#
#   No TLS needed here — the main Caddy already handles HTTPS.
#
# To add a new route:
#   1. Add a handle_path block:
#        handle_path /myapp/* {
#            reverse_proxy localhost:4003
#        }
#   2. Reload (no sudo needed):
#        caddy reload --config /srv/<ai-user>/Caddyfile --address localhost:2020
#
# To remove a route:
#   Delete its handle_path block and reload.
#
# Admin API:
#   This instance uses port 2020 for its admin API (main Caddy uses 2019).
#   The AI can query it: curl localhost:2020/config/
# =============================================================================

{
    # Separate admin API port — avoids conflict with main Caddy's default (:2019)
    admin localhost:2020
}

# Listen on port 4000 — receives traffic forwarded from main Caddy
:4000 {
    # Example routes — AI adds/removes these as it deploys projects
    # Each handle_path strips the prefix before forwarding

    handle_path /dash/* {
        reverse_proxy localhost:4001
    }

    handle_path /api/* {
        reverse_proxy localhost:4002
    }

    # Fallback — responds to any path not matched above
    handle {
        respond "ai sandbox is running" 200
    }
}
